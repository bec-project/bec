// Project-local debug tasks
//
// For more documentation on how to configure debug tasks,
// see: https://zed.dev/docs/debugger
[
  {
    "adapter": "Debugpy",
    "label": "Debug current python file",
    "justMyCode": false,
    "program": "${ZED_FILE}",
    "request": "launch",
    "env": {
      "PYDEVD_FILTER_LIBRARIES": "0",
    },
  },
]
